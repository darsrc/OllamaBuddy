# Copy to .env and customise

HOST=0.0.0.0
PORT=8000
DEBUG=false

# Ollama
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=qwen2.5:9b

# Whisper STT  (tiny | base | small | medium | large-v3)
WHISPER_MODEL=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# TTS
DEFAULT_VOICE=af_heart
DEFAULT_TTS_SPEED=1.0
DEFAULT_TTS_MODE=punctuation

# Speaker ID
SPEAKER_THRESHOLD=0.75
ENROLLMENT_SAMPLES_REQUIRED=3

# SearXNG (optional)
SEARXNG_URL=http://localhost:8888
